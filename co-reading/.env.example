# 共读书房 Co-Reading Room — 环境变量模板
# 复制为 .env 并填入真实值

# 用户名
COREADING_USER=Reader

# 记忆压缩模型配置
# 支持任意 OpenAI 兼容端点：Anthropic, OpenRouter, 硅基流动, Ollama 等
SUMMARY_API_BASE=https://api.openai.com/v1
SUMMARY_API_KEY=your-key-here
SUMMARY_MODEL=gpt-4o-mini

# RAG 向量检索 Embedding 配置
# 默认指向本地 Ollama，也支持云端 OpenAI 兼容端点
EMBEDDING_API_BASE=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text

# MCP HTTP 传输配置（start_http.bat 使用）
MCP_HOST=127.0.0.1
MCP_PORT=8766
